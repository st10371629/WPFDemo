<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:av="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="av" x:Class="WpfApp1.MainWindow"
        Title="ChatBot" Height="500" Width="900" Background="White">

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#F2F2F2" CornerRadius="12" Margin="0,0,15,0" BorderBrush="#DCDCDC" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="40"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#E8E8E8" CornerRadius="12,12,0,0">
                    <TextBlock Text="ChatBot" VerticalAlignment="Center" Margin="15,0" 
                               FontWeight="Bold" Foreground="#7C89F5" FontSize="16"/>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="15">
                    <StackPanel x:Name="ChatStack">
                        <Border Background="#E0E0E0" CornerRadius="15,15,15,0" HorizontalAlignment="Left" Padding="12,8" Margin="0,5">
                            <TextBlock Text="Hello! I am ready to help. Ask me anything!" TextWrapping="Wrap" MaxWidth="350"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <TextBlock Grid.Row="2" x:Name="TxtStatus" Text="Chatbot is ready..." Margin="15,0" 
                           FontStyle="Italic" Foreground="Gray" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="#F2F2F2" CornerRadius="12" BorderBrush="#DCDCDC" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#E8E8E8" CornerRadius="12,12,0,0">
                    <TextBlock Text="Input" VerticalAlignment="Center" Margin="15,0" 
                               FontWeight="Bold" Foreground="#7C89F5" FontSize="16"/>
                </Border>

                <StackPanel Grid.Row="1" Margin="15">
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,20" FontSize="14"><Run Text="Welcome to "/><Run Text="ChatBot" Foreground="#7C89F5" FontWeight="Bold"/><Run Text="! Enter your question and click SEND."/></TextBlock>

                    <Border Background="White" CornerRadius="8" BorderBrush="#DCDCDC" BorderThickness="1" Height="120">
                        <TextBox x:Name="UserInput" Text="Click here to enter message" Foreground="Gray" GotFocus="UserInput_GotFocus" 
                                 LostFocus="UserInput_LostFocus" Margin="8" BorderThickness="0" TextWrapping="Wrap" AcceptsReturn="True"/>
                    </Border>

                    <Button x:Name="BtnSend" Click="BtnSend_Click" Content="SEND" Margin="0,20,0,0" Height="45" 
                            Background="#ABB7FF" Foreground="White" FontWeight="Bold" BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="BtnClear" Click="BtnClear_Click" Content="CLEAR CHAT" Margin="0,20,0,0" Height="45" 
                            Background="#F88C91" Foreground="White" FontWeight="Bold" BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>